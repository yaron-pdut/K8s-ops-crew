# LLM provider
OPENAI_API_KEY=sk-...

# LangSmith tracing (set to true to enable)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=k8s-ops-crew

# Kubernetes config (defaults to ~/.kube/config if unset)
# KUBECONFIG=/path/to/your/kubeconfig

# LLM model selection (defaults used by config.py)
# SUPERVISOR_MODEL=gpt-4o
# DIAGNOSTICS_MODEL=gpt-4o-mini

# Safety: set to true to skip any mutating operations (Phase 3+)
DRY_RUN=true
